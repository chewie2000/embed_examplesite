# Sigma Embed Credentials
# Obtain these from your Sigma org: Administration > Developer Access > Embedding
SIGMA_CLIENT_ID=
SIGMA_SECRET=

# Sigma Embed Base URL
# The published workbook/page URL from Sigma (without ?:embed=true)
# This is the default embed shown when no mode is active.
SIGMA_BASE_URL=

# Add one per nav section in DashboardShell.js NAV_ITEMS.
# The mode name (uppercase) becomes the env var prefix.
# Example: { label: 'Sales', mode: 'sales' } → SALES_SIGMA_BASE_URL
# SALES_SIGMA_BASE_URL=
# PROFIT_PLANNER_SIGMA_BASE_URL=
# MARKETING_SIGMA_BASE_URL=

# Session secret — generate a strong random string (e.g. openssl rand -base64 32)
SESSION_SECRET=

# Optional: embed session length in seconds (default 3600 = 1 hour, max 2592000 = 30 days)
# SESSION_LENGTH=3600

# Optional: Sigma UI controls (uncomment to enable)
# hide_menu=true
# hide_folder_navigation=true
# disable_mobile_view=true
# responsive_height=true
# theme=
# lng=
